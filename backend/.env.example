NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# PostgreSQL (port 5433 to avoid conflict with other local instances)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=eadeies
DB_USER=eadeies
DB_PASS=eadeies

# Auth
JWT_SECRET=change-this-in-production

# Redis (for BullMQ email queue)
REDIS_URL=redis://localhost:6379

# MinIO (file storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=openadeia

# Frontend CORS
FRONTEND_URL=http://localhost:3000

# TEE portal overrides (optional — defaults work for production)
# TEE_API_BASE=https://services.tee.gr
# TEE_SSO_BASE=https://sso.tee.gr

# ── SaaS / Multi-tenancy ──────────────────────────────────────────────
# Set to true to enable multi-tenant mode (tenant isolation, billing, etc.)
# SAAS_MODE=false

# ── Stripe Billing (SaaS only) ────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
# Leave unset for self-hosted installs (billing routes won't register)
#
# STRIPE_SECRET_KEY=sk_live_...         # Live secret key (or sk_test_... for testing)
# STRIPE_WEBHOOK_SECRET=whsec_...       # Webhook signing secret (Stripe Dashboard → Webhooks)
#
# Price IDs for each plan (Stripe Dashboard → Products → Prices)
# STRIPE_PRICE_PRO=price_...            # Monthly/annual price for Pro plan
# STRIPE_PRICE_ENTERPRISE=price_...     # Monthly/annual price for Enterprise plan
